{
   "name": "mnist-digits",
   "version": "1.0.0",
   "description": "MNIST model to detect digits 0-9",
   "author": "Umer Majeed (infinite Zero)",
   "technical details": "",
   "Genesis_Model_CID": "bafybeia6hlf3dpptyomuufvswsqjawfr6dizqsuo7tj65wia27crwdgc2a",
   "DINTaskCoordinator_Contract": "0x8464135c8F25Da09e49BC8782676a84730C318bC",
   "DINTaskAuditor_Contract": "0x71C95911E9a5D330f4D621842EC243EE1343292e",
   "audit_scoring_policy": {
      "spec_version": 1,
      "pass_scoring": {
         "enabled": true,
         "threshold": 5
      },
      "scenario": "labeled_holdout_classification",
      "admission_mode": "holdout_delta",
      "contribution_mode": "none",
      "fallback_mode": "screening_only",
      "algorithms": {
         "eligibility": "eligibility_anomaly_gate",
         "utility": "holdout_delta_score",
         "validator_aggregation": "legacy_mean_until_contract_v2"
      },
      "normalization": {
         "contract_score_scale": "percent_0_100",
         "utility_scale": "basis_points",
         "max_utility": 10000
      },
      "eligibility_checks": {
         "require_loadable_model": true,
         "require_architecture_match": true,
         "reject_nan_tensors": true,
         "max_update_norm": 100.0,
         "max_abs_weight": 100.0,
         "min_eval_examples": 1
      },
      "evaluation": {
         "batch_size": 32,
         "dataset_mode": "legacy_testDataCID",
         "metric_bundle_upload": "best_effort"
      },
      "metrics": {
         "primary": [
            "accuracy",
            "loss",
            "macro_f1",
            "baseline_delta"
         ],
         "thresholds": {
            "min_accuracy": 50.0,
            "min_baseline_delta_bps": 0,
            "max_anomaly_score_bps": 5000
         }
      },
      "validator_consensus": {
         "acceptance_rule": "legacy_contract_quorum",
         "target_acceptance_rule_v2": "majority_vote",
         "target_score_rule_v2": "median",
         "max_disagreement_bps": 800
      }
   },
   "gm_scoring_policy": {
      "evaluation": {
         "requires_test_dataset": true,
         "dataset_mode": "path"
      }
   },
   "dp": {
      "enabled": false,
      "mode": "afterTraining",
      "mechanism": "post_training_gaussian",
      "parameters": {
         "clipping_norm": 1.0,
         "noise_multiplier": 0.5,
         "laplace_scale": 0.35,
         "clip_scope": "per_layer"
      }
   },
